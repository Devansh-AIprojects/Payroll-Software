# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mill_payroll

# Redis
REDIS_URL=redis://localhost:6379

# Auth — HS256 JWT signed by this app
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_64_char_hex_secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Fingerprint template encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_generated_fernet_key=
# App
APP_ENV=development
APP_DEBUG=true

#Biomax device setting ADMS url to my railway domain 
http://your-app.railway.app/iclock/cdata